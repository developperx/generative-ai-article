---
import Layout from '../layouts/Layout.astro';
import data from '../../data/items.json';

const { items, updatedAt, sources = [] } = data as {
  items: any[];
  updatedAt: string;
  sources: { id: string; name: string }[];
};

const allTags = [...new Set(items.flatMap((i) => i.tags ?? []))].sort();
const sourceNames = sources.length
  ? sources.map((s) => s.name)
  : [...new Set(items.map((i) => i.source))];

const updatedLabel = new Intl.DateTimeFormat('ja-JP', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'Asia/Tokyo',
}).format(new Date(updatedAt));

function formatDate(iso: string | null): string {
  if (!iso) return '日付不明';
  return new Intl.DateTimeFormat('ja-JP', {
    month: 'numeric',
    day: 'numeric',
    timeZone: 'Asia/Tokyo',
  }).format(new Date(iso));
}
---

<Layout>
  <a class="skip-link" href="#feed">本文へスキップ</a>

  <header class="site-header">
    <div class="wrap header-inner">
      <div class="brand">
        <span class="logo" aria-hidden="true">⚡</span>
        <div>
          <h1>生成AIトレンド</h1>
          <p class="tagline">最新の活用情報を自動でまとめてチェック</p>
        </div>
      </div>
      <button id="theme-toggle" class="icon-btn" type="button" aria-label="テーマ切り替え">
        <span class="theme-icon">🌙</span>
      </button>
    </div>
  </header>

  <main class="wrap">
    <section class="controls" aria-label="絞り込み">
      <div class="search-row">
        <input
          id="search"
          type="search"
          inputmode="search"
          placeholder="キーワードで検索（例: コーディング, 画像生成）"
          aria-label="キーワード検索"
        />
        <select id="sort" aria-label="並べ替え">
          <option value="new">新着順</option>
          <option value="bookmarks">話題順（ブクマ数）</option>
        </select>
      </div>

      <div class="filter-row">
        <select id="source-filter" aria-label="出典で絞り込み">
          <option value="">すべての出典</option>
          {sourceNames.map((name) => <option value={name}>{name}</option>)}
        </select>
        <select id="period-filter" aria-label="期間で絞り込み">
          <option value="">すべての期間</option>
          <option value="1">今日</option>
          <option value="7">今週</option>
          <option value="30">今月</option>
        </select>
        <label class="saved-toggle">
          <input id="saved-only" type="checkbox" />
          <span>★ あとで読むのみ</span>
        </label>
      </div>

      <div class="tag-chips" id="tag-chips" role="group" aria-label="タグで絞り込み">
        {allTags.map((tag) => (
          <button class="chip" type="button" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </section>

    <div class="meta-bar">
      <span id="result-count">{items.length} 件</span>
      <span class="updated">最終更新: {updatedLabel}（JST）</span>
    </div>

    <section id="feed" class="feed" aria-live="polite">
      {items.map((item) => (
        <article
          class="card"
          data-id={item.id}
          data-source={item.source}
          data-tags={(item.tags ?? []).join('||')}
          data-date={item.publishedAt ?? ''}
          data-bm={item.bookmarkCount ?? 0}
          data-title={`${item.title} ${item.snippet ?? ''}`.toLowerCase()}
        >
          <div class="card-head">
            <span class="source-badge">{item.source}</span>
            <button
              class="save-btn"
              type="button"
              aria-label="あとで読むに追加"
              aria-pressed="false"
              data-save={item.id}
            >★</button>
          </div>
          <h2 class="card-title">
            <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
          </h2>
          {item.snippet && <p class="card-snippet">{item.snippet}</p>}
          <div class="card-foot">
            <span class="date">{formatDate(item.publishedAt)}</span>
            {item.bookmarkCount != null && (
              <span class="bm" title="はてなブックマーク数">★ {item.bookmarkCount}</span>
            )}
            <span class="card-tags">
              {(item.tags ?? []).map((t: string) => <span class="mini-tag">{t}</span>)}
            </span>
          </div>
        </article>
      ))}
    </section>

    <p id="empty-state" class="empty" hidden>条件に一致する記事がありません。</p>
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p>
        本サイトは各メディアの公式RSS・公開APIから記事の見出し・出典・リンクを集約して表示しています。
        本文の著作権は各配信元に帰属します。詳細は各記事リンク先をご覧ください。
      </p>
    </div>
  </footer>
</Layout>

<style>
  .wrap {
    width: 100%;
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 16px;
  }
  .skip-link {
    position: absolute;
    left: -9999px;
  }
  .skip-link:focus {
    left: 8px;
    top: 8px;
    background: var(--surface);
    padding: 8px 12px;
    border-radius: 8px;
    z-index: 10;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 5;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    padding-bottom: 12px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo {
    font-size: 24px;
  }
  h1 {
    margin: 0;
    font-size: 19px;
    letter-spacing: 0.01em;
  }
  .tagline {
    margin: 0;
    font-size: 12px;
    color: var(--muted);
  }
  .icon-btn {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    width: 40px;
    height: 40px;
    border-radius: 10px;
    font-size: 18px;
    cursor: pointer;
  }
  .icon-btn:hover {
    border-color: var(--accent);
  }

  .controls {
    margin-top: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .search-row {
    display: flex;
    gap: 8px;
  }
  #search {
    flex: 1;
    min-width: 0;
    padding: 11px 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    color: var(--text);
    font-size: 16px;
  }
  #search:focus,
  select:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }
  .filter-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  select {
    padding: 9px 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    color: var(--text);
    font-size: 14px;
    cursor: pointer;
  }
  .saved-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--muted);
    cursor: pointer;
    user-select: none;
  }
  .tag-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }
  .chip {
    border: 1px solid var(--border);
    background: var(--chip);
    color: var(--text);
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.12s ease;
  }
  .chip:hover {
    border-color: var(--accent);
  }
  .chip[aria-pressed='true'] {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .meta-bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin: 16px 0 10px;
    font-size: 13px;
    color: var(--muted);
    gap: 8px;
    flex-wrap: wrap;
  }
  #result-count {
    font-weight: 600;
    color: var(--text);
  }

  .feed {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    padding-bottom: 32px;
  }
  @media (min-width: 720px) {
    .feed {
      grid-template-columns: 1fr 1fr;
    }
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }
  .source-badge {
    font-size: 12px;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 3px 9px;
    border-radius: 6px;
    font-weight: 600;
  }
  .save-btn {
    border: none;
    background: transparent;
    color: var(--muted);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    padding: 2px 4px;
  }
  .save-btn[aria-pressed='true'] {
    color: #f5a623;
  }
  .card-title {
    margin: 0;
    font-size: 16px;
    line-height: 1.45;
  }
  .card-title a {
    text-decoration: none;
  }
  .card-title a:hover {
    text-decoration: underline;
    color: var(--accent);
  }
  .card-snippet {
    margin: 0;
    font-size: 13.5px;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-foot {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--muted);
  }
  .bm {
    color: #f5a623;
    font-weight: 600;
  }
  .card-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    margin-left: auto;
  }
  .mini-tag {
    background: var(--chip);
    border-radius: 5px;
    padding: 2px 7px;
    font-size: 11px;
  }
  .empty {
    text-align: center;
    color: var(--muted);
    padding: 40px 0;
  }
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 20px 0 40px;
    font-size: 12px;
    color: var(--muted);
  }
  .site-footer p {
    margin: 0;
    line-height: 1.7;
  }
</style>

<script>
  type Filters = {
    q: string;
    source: string;
    period: string;
    tags: Set<string>;
    savedOnly: boolean;
    sort: string;
  };

  const SAVED_KEY = 'savedItems';
  const getSaved = (): Set<string> =>
    new Set(JSON.parse(localStorage.getItem(SAVED_KEY) || '[]'));
  const setSaved = (s: Set<string>) =>
    localStorage.setItem(SAVED_KEY, JSON.stringify([...s]));

  const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
  const feed = document.getElementById('feed')!;
  const resultCount = document.getElementById('result-count')!;
  const emptyState = document.getElementById('empty-state')!;

  const filters: Filters = {
    q: '',
    source: '',
    period: '',
    tags: new Set(),
    savedOnly: false,
    sort: 'new',
  };

  // --- あとで読む（localStorage） ---
  function initSaved() {
    const saved = getSaved();
    document.querySelectorAll<HTMLButtonElement>('[data-save]').forEach((btn) => {
      const id = btn.dataset.save!;
      const on = saved.has(id);
      btn.setAttribute('aria-pressed', String(on));
      btn.addEventListener('click', () => {
        const cur = getSaved();
        if (cur.has(id)) cur.delete(id);
        else cur.add(id);
        setSaved(cur);
        btn.setAttribute('aria-pressed', String(cur.has(id)));
        if (filters.savedOnly) apply();
      });
    });
  }

  // --- フィルタ適用 ---
  function apply() {
    const saved = getSaved();
    const now = Date.now();
    let visible = 0;

    const shown: HTMLElement[] = [];
    for (const card of cards) {
      const title = card.dataset.title || '';
      const source = card.dataset.source || '';
      const tags = (card.dataset.tags || '').split('||').filter(Boolean);
      const date = card.dataset.date ? Date.parse(card.dataset.date) : 0;
      const id = card.dataset.id!;

      let ok = true;
      if (filters.q && !title.includes(filters.q)) ok = false;
      if (filters.source && source !== filters.source) ok = false;
      if (filters.savedOnly && !saved.has(id)) ok = false;
      if (filters.tags.size && ![...filters.tags].every((t) => tags.includes(t))) ok = false;
      if (filters.period && date) {
        const days = (now - date) / 86400000;
        if (days > Number(filters.period)) ok = false;
      }

      card.hidden = !ok;
      if (ok) {
        visible++;
        shown.push(card);
      }
    }

    // 並べ替え（表示中のカードのみ並び替えてDOMに反映）
    shown.sort((a, b) => {
      if (filters.sort === 'bookmarks') {
        return Number(b.dataset.bm) - Number(a.dataset.bm);
      }
      return (Date.parse(b.dataset.date || '0') || 0) - (Date.parse(a.dataset.date || '0') || 0);
    });
    shown.forEach((c) => feed.appendChild(c));

    resultCount.textContent = `${visible} 件`;
    emptyState.hidden = visible !== 0;
  }

  // --- イベント配線 ---
  const search = document.getElementById('search') as HTMLInputElement;
  search.addEventListener('input', () => {
    filters.q = search.value.trim().toLowerCase();
    apply();
  });

  (document.getElementById('source-filter') as HTMLSelectElement).addEventListener('change', (e) => {
    filters.source = (e.target as HTMLSelectElement).value;
    apply();
  });
  (document.getElementById('period-filter') as HTMLSelectElement).addEventListener('change', (e) => {
    filters.period = (e.target as HTMLSelectElement).value;
    apply();
  });
  (document.getElementById('sort') as HTMLSelectElement).addEventListener('change', (e) => {
    filters.sort = (e.target as HTMLSelectElement).value;
    apply();
  });
  (document.getElementById('saved-only') as HTMLInputElement).addEventListener('change', (e) => {
    filters.savedOnly = (e.target as HTMLInputElement).checked;
    apply();
  });

  document.querySelectorAll<HTMLButtonElement>('.chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const tag = chip.dataset.tag!;
      if (filters.tags.has(tag)) {
        filters.tags.delete(tag);
        chip.setAttribute('aria-pressed', 'false');
      } else {
        filters.tags.add(tag);
        chip.setAttribute('aria-pressed', 'true');
      }
      apply();
    });
  });

  // --- テーマ切り替え ---
  const themeToggle = document.getElementById('theme-toggle')!;
  const themeIcon = themeToggle.querySelector('.theme-icon')!;
  function syncIcon() {
    themeIcon.textContent = document.documentElement.dataset.theme === 'dark' ? '☀️' : '🌙';
  }
  syncIcon();
  themeToggle.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
    syncIcon();
  });

  initSaved();
  apply();
</script>
