---
import Layout from '../layouts/Layout.astro';
import data from '../../data/items.json';

const { items, updatedAt, sources = [] } = data as {
  items: any[];
  updatedAt: string;
  sources: { id: string; name: string }[];
};

const allTags = [...new Set(items.flatMap((i) => i.tags ?? []))].sort();
const sourceNames = sources.length
  ? sources.map((s) => s.name)
  : [...new Set(items.map((i) => i.source))];

const updatedLabel = new Intl.DateTimeFormat('ja-JP', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'Asia/Tokyo',
}).format(new Date(updatedAt));

function formatDate(iso: string | null): string {
  if (!iso) return '—';
  return new Intl.DateTimeFormat('ja-JP', {
    month: 'numeric',
    day: 'numeric',
    timeZone: 'Asia/Tokyo',
  }).format(new Date(iso));
}
---

<Layout>
  <a class="skip-link" href="#feed">本文へスキップ</a>

  <header class="site-header">
    <div class="wrap header-inner">
      <div class="brand">
        <span class="signal-dot" aria-hidden="true"></span>
        <div class="brand-text">
          <h1>生成AI<span class="brand-accent">トレンド</span></h1>
          <p class="tagline">AI情報を自動集約<span class="tag-sep"> · </span>DAILY UPDATED</p>
        </div>
      </div>
      <button id="theme-toggle" class="icon-btn" type="button" aria-label="テーマ切り替え">
        <span class="theme-icon">☀️</span>
      </button>
    </div>
  </header>

  <main class="wrap">
    <section class="controls" aria-label="絞り込み">
      <div class="search-row">
        <div class="search-wrap">
          <span class="search-prompt" aria-hidden="true">›</span>
          <input
            id="search"
            type="search"
            inputmode="search"
            placeholder="キーワードで検索（例: コーディング, 画像生成）"
            aria-label="キーワード検索"
          />
        </div>
        <div class="select-wrap">
          <select id="sort" aria-label="並べ替え">
            <option value="new">新着順</option>
            <option value="bookmarks">話題順（ブクマ数）</option>
          </select>
        </div>
      </div>

      <div class="filter-row">
        <div class="select-wrap">
          <select id="source-filter" aria-label="出典で絞り込み">
            <option value="">すべての出典</option>
            {sourceNames.map((name) => <option value={name}>{name}</option>)}
          </select>
        </div>
        <div class="select-wrap">
          <select id="period-filter" aria-label="期間で絞り込み">
            <option value="">すべての期間</option>
            <option value="1">今日</option>
            <option value="7">今週</option>
            <option value="30">今月</option>
          </select>
        </div>
        <label class="saved-toggle">
          <input id="saved-only" type="checkbox" />
          <span>★ あとで読む</span>
        </label>
      </div>

      <div class="tag-chips" id="tag-chips" role="group" aria-label="タグで絞り込み">
        {allTags.map((tag) => (
          <button class="chip" type="button" data-tag={tag} aria-pressed="false">{tag}</button>
        ))}
      </div>
    </section>

    <div class="meta-bar">
      <span class="meta-count"><span id="result-count">{items.length}</span> 件</span>
      <span class="updated">最終更新: {updatedLabel}（JST）</span>
    </div>

    <section id="feed" class="feed" aria-live="polite">
      {items.map((item, i) => (
        <article
          class="card"
          data-id={item.id}
          data-source={item.source}
          data-tags={(item.tags ?? []).join('||')}
          data-date={item.publishedAt ?? ''}
          data-bm={item.bookmarkCount ?? 0}
          data-title={`${item.title} ${item.snippet ?? ''}`.toLowerCase()}
          style={`animation-delay: ${Math.min(i * 0.04, 0.6)}s`}
        >
          <div class="card-head">
            <span class="source-badge">{item.source}</span>
            <button
              class="save-btn"
              type="button"
              aria-label="あとで読むに追加"
              aria-pressed="false"
              data-save={item.id}
            >★</button>
          </div>
          <h2 class="card-title">
            <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
          </h2>
          {item.snippet && <p class="card-snippet">{item.snippet}</p>}
          <div class="card-foot">
            <span class="date">{formatDate(item.publishedAt)}</span>
            {item.bookmarkCount != null && (
              <span class="bm">★ {item.bookmarkCount}</span>
            )}
            <span class="card-tags">
              {(item.tags ?? []).map((t: string) => <span class="mini-tag">{t}</span>)}
            </span>
          </div>
        </article>
      ))}
    </section>

    <div id="empty-state" class="empty" hidden>
      <span class="empty-icon" aria-hidden="true">◎</span>
      <span>条件に一致する記事がありません</span>
      <button id="reset-filters" class="reset-btn" type="button">絞り込みをリセット</button>
    </div>
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p class="footer-text">
        本サイトは各メディアの公式RSS・公開APIから記事の見出し・出典・リンクを集約して表示しています。
        本文の著作権は各配信元に帰属します。詳細は各記事リンク先をご覧ください。
      </p>
    </div>
  </footer>
</Layout>

<style>
  /* ========= Layout ========= */
  .wrap {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 max(20px, env(safe-area-inset-left)) 0 max(20px, env(safe-area-inset-right));
  }
  .skip-link {
    position: absolute;
    left: -9999px;
  }
  .skip-link:focus {
    left: 10px;
    top: 10px;
    background: var(--surface);
    padding: 8px 14px;
    border-radius: var(--radius);
    z-index: var(--z-overlay);
    border: 1px solid var(--accent);
  }

  /* ========= Header ========= */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    padding-top: env(safe-area-inset-top);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 13px;
    padding-bottom: 13px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 13px;
  }
  .signal-dot {
    display: block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft), 0 0 12px var(--accent-glow);
    animation: signalPulse 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes signalPulse {
    0%, 100% {
      opacity: 1;
      box-shadow: 0 0 0 3px var(--accent-soft), 0 0 12px var(--accent-glow);
    }
    50% {
      opacity: 0.5;
      box-shadow: 0 0 0 6px var(--accent-soft), 0 0 4px transparent;
    }
  }
  .brand-text h1 {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    text-wrap: balance;
  }
  .brand-accent {
    color: var(--accent);
  }
  .tagline {
    margin: 0;
    margin-top: 3px;
    font-size: 10px;
    color: var(--muted);
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    line-height: 1;
    text-transform: uppercase;
  }
  .tag-sep {
    color: var(--accent);
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    border-radius: var(--radius-sm);
    font-size: 15px;
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
    flex-shrink: 0;
  }
  .icon-btn:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  /* ========= Controls ========= */
  .controls {
    margin-top: 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .search-row {
    display: flex;
    gap: 8px;
  }
  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 0;
  }
  .search-prompt {
    position: absolute;
    left: 13px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 500;
    pointer-events: none;
    line-height: 1;
    user-select: none;
  }
  #search {
    width: 100%;
    padding: 11px 14px 11px 33px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    font-size: 15px;
    font-family: var(--font-body);
    transition: border-color 0.15s, box-shadow 0.15s;
    appearance: none;
  }
  #search:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  #search::placeholder { color: var(--muted); }

  .filter-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .select-wrap {
    position: relative;
  }
  .select-wrap::after {
    content: '▾';
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    font-size: 10px;
    color: var(--muted);
    font-family: var(--font-mono);
  }
  select {
    appearance: none;
    -webkit-appearance: none;
    padding: 10px 28px 10px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    font-size: 13px;
    font-family: var(--font-body);
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  select:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .saved-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--muted);
    cursor: pointer;
    user-select: none;
    padding: 10px 13px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .saved-toggle:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }
  .saved-toggle input {
    accent-color: var(--secondary);
    width: 14px;
    height: 14px;
    cursor: pointer;
  }

  /* ========= Tag Chips ========= */
  .tag-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .chip {
    border: 1px solid var(--border);
    background: var(--chip);
    color: var(--muted);
    padding: 5px 13px;
    border-radius: 999px;
    font-size: 12px;
    font-family: var(--font-mono);
    cursor: pointer;
    transition: border-color 0.15s ease-out, color 0.15s ease-out, background-color 0.15s ease-out;
    letter-spacing: 0.01em;
  }
  .chip:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-soft);
  }
  .chip[aria-pressed='true'] {
    background: var(--accent);
    border-color: var(--accent);
    color: #020e0b;
    font-weight: 600;
  }

  /* ========= Meta Bar ========= */
  .meta-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 20px 0 14px;
    font-family: var(--font-mono);
    color: var(--muted);
    font-size: 12px;
  }
  .meta-count {
    color: var(--text);
    font-size: 12px;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }
  #result-count {
    color: var(--accent);
    font-weight: 600;
    font-size: 16px;
    font-variant-numeric: tabular-nums;
  }
  .updated {
    font-size: 10px;
    letter-spacing: 0.03em;
  }

  /* ========= Feed Grid ========= */
  .feed {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    padding-bottom: 52px;
  }
  @media (min-width: 640px) {
    .feed { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1000px) {
    .feed { grid-template-columns: 1fr 1fr 1fr; }
  }

  /* ========= Cards ========= */
  @keyframes cardReveal {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent-dim);
    border-radius: var(--radius);
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: border-color 0.2s ease-out, border-left-color 0.2s ease-out, box-shadow 0.2s ease-out, transform 0.2s ease-out;
    animation: cardReveal 0.45s ease-out both;
  }
  .card[hidden] { display: none; }
  .card:hover {
    border-left-color: var(--accent);
    border-color: var(--border-hover);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }
  .source-badge {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--accent);
    background: var(--accent-soft);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 180px;
  }
  .save-btn {
    border: none;
    background: transparent;
    color: var(--muted);
    font-size: 15px;
    line-height: 1;
    cursor: pointer;
    padding: 2px 4px;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .save-btn:hover { color: var(--secondary); }
  .save-btn[aria-pressed='true'] { color: var(--secondary); }

  .card-title {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.5;
    text-wrap: balance;
  }
  .card-title a { text-decoration: none; }
  .card-title a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .card-snippet {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-foot {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }
  .bm {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--secondary);
    font-weight: 600;
    background: var(--secondary-soft);
    padding: 1px 7px;
    border-radius: 4px;
    font-variant-numeric: tabular-nums;
  }
  .card-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-left: auto;
  }
  .mini-tag {
    background: var(--chip);
    color: var(--muted);
    border-radius: 4px;
    padding: 1px 7px;
    font-size: 10px;
    font-family: var(--font-mono);
    letter-spacing: 0.01em;
  }

  /* ========= Empty State ========= */
  .empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
    color: var(--muted);
    padding: 64px 0;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.03em;
  }
  .empty-icon {
    font-size: 36px;
    color: var(--border-hover);
    line-height: 1;
  }
  .reset-btn {
    margin-top: 2px;
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    font-size: 13px;
    font-family: var(--font-body);
    cursor: pointer;
    transition: border-color 0.15s ease-out, color 0.15s ease-out;
  }
  .reset-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ========= Footer ========= */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 24px 0 calc(52px + env(safe-area-inset-bottom));
  }
  .footer-text {
    margin: 0;
    font-size: 11px;
    color: var(--muted);
    font-family: var(--font-mono);
    line-height: 1.9;
    letter-spacing: 0.01em;
    text-wrap: pretty;
  }
</style>

<script>
  type Filters = {
    q: string;
    source: string;
    period: string;
    tags: Set<string>;
    savedOnly: boolean;
    sort: string;
  };

  const SAVED_KEY = 'savedItems';
  const getSaved = (): Set<string> =>
    new Set(JSON.parse(localStorage.getItem(SAVED_KEY) || '[]'));
  const setSaved = (s: Set<string>) =>
    localStorage.setItem(SAVED_KEY, JSON.stringify([...s]));

  const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
  const feed = document.getElementById('feed')!;
  const resultCount = document.getElementById('result-count')!;
  const emptyState = document.getElementById('empty-state')!;

  const filters: Filters = {
    q: '',
    source: '',
    period: '',
    tags: new Set(),
    savedOnly: false,
    sort: 'new',
  };

  // --- あとで読む（localStorage） ---
  function initSaved() {
    const saved = getSaved();
    document.querySelectorAll<HTMLButtonElement>('[data-save]').forEach((btn) => {
      const id = btn.dataset.save!;
      const on = saved.has(id);
      btn.setAttribute('aria-pressed', String(on));
      btn.addEventListener('click', () => {
        const cur = getSaved();
        if (cur.has(id)) cur.delete(id);
        else cur.add(id);
        setSaved(cur);
        btn.setAttribute('aria-pressed', String(cur.has(id)));
        if (filters.savedOnly) apply();
      });
    });
  }

  // --- フィルタ適用 ---
  function apply() {
    const saved = getSaved();
    const now = Date.now();
    let visible = 0;

    const shown: HTMLElement[] = [];
    for (const card of cards) {
      const title = card.dataset.title || '';
      const source = card.dataset.source || '';
      const tags = (card.dataset.tags || '').split('||').filter(Boolean);
      const date = card.dataset.date ? Date.parse(card.dataset.date) : 0;
      const id = card.dataset.id!;

      let ok = true;
      if (filters.q && !title.includes(filters.q)) ok = false;
      if (filters.source && source !== filters.source) ok = false;
      if (filters.savedOnly && !saved.has(id)) ok = false;
      if (filters.tags.size && ![...filters.tags].every((t) => tags.includes(t))) ok = false;
      if (filters.period && date) {
        const days = (now - date) / 86400000;
        if (days > Number(filters.period)) ok = false;
      }

      card.hidden = !ok;
      if (ok) {
        visible++;
        shown.push(card);
      }
    }

    // 並べ替え（表示中のカードのみ並び替えてDOMに反映）
    shown.sort((a, b) => {
      if (filters.sort === 'bookmarks') {
        return Number(b.dataset.bm) - Number(a.dataset.bm);
      }
      return (Date.parse(b.dataset.date || '0') || 0) - (Date.parse(a.dataset.date || '0') || 0);
    });
    shown.forEach((c) => feed.appendChild(c));

    resultCount.textContent = `${visible}`;
    emptyState.hidden = visible !== 0;
  }

  // --- イベント配線 ---
  const search = document.getElementById('search') as HTMLInputElement;
  search.addEventListener('input', () => {
    filters.q = search.value.trim().toLowerCase();
    apply();
  });

  (document.getElementById('source-filter') as HTMLSelectElement).addEventListener('change', (e) => {
    filters.source = (e.target as HTMLSelectElement).value;
    apply();
  });
  (document.getElementById('period-filter') as HTMLSelectElement).addEventListener('change', (e) => {
    filters.period = (e.target as HTMLSelectElement).value;
    apply();
  });
  (document.getElementById('sort') as HTMLSelectElement).addEventListener('change', (e) => {
    filters.sort = (e.target as HTMLSelectElement).value;
    apply();
  });
  (document.getElementById('saved-only') as HTMLInputElement).addEventListener('change', (e) => {
    filters.savedOnly = (e.target as HTMLInputElement).checked;
    apply();
  });

  document.querySelectorAll<HTMLButtonElement>('.chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const tag = chip.dataset.tag!;
      if (filters.tags.has(tag)) {
        filters.tags.delete(tag);
        chip.setAttribute('aria-pressed', 'false');
      } else {
        filters.tags.add(tag);
        chip.setAttribute('aria-pressed', 'true');
      }
      apply();
    });
  });

  // --- 絞り込みリセット（空状態の次アクション） ---
  document.getElementById('reset-filters')?.addEventListener('click', () => {
    filters.q = '';
    filters.source = '';
    filters.period = '';
    filters.savedOnly = false;
    filters.tags.clear();
    search.value = '';
    (document.getElementById('source-filter') as HTMLSelectElement).value = '';
    (document.getElementById('period-filter') as HTMLSelectElement).value = '';
    (document.getElementById('saved-only') as HTMLInputElement).checked = false;
    document.querySelectorAll<HTMLButtonElement>('.chip').forEach((chip) =>
      chip.setAttribute('aria-pressed', 'false'),
    );
    apply();
  });

  // --- テーマ切り替え ---
  const themeToggle = document.getElementById('theme-toggle')!;
  const themeIcon = themeToggle.querySelector('.theme-icon')!;
  function syncIcon() {
    themeIcon.textContent = document.documentElement.dataset.theme === 'dark' ? '☀️' : '🌙';
  }
  syncIcon();
  themeToggle.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
    syncIcon();
  });

  initSaved();
  apply();
</script>
