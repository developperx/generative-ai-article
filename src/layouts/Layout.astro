---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = '生成AIトレンド | 最新の活用情報をまとめてチェック',
  description = '生成AIの活用方法に関する最新トレンドを、公式RSS・公開APIから自動集約。タイトルと出典・リンク中心で素早くチェックできます。',
} = Astro.props;
---

<!doctype html>
<html lang="ja" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
    <!-- フラッシュ防止: テーマを描画前に適用 -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'light') {
          document.documentElement.dataset.theme = 'light';
        } else if (!t && !window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        --bg: #060a10;
        --surface: #0c1322;
        --surface-hover: #111c30;
        --border: #16243a;
        --border-hover: #1e3050;
        --text: #d6e2f0;
        --muted: #4a6380;
        --accent: #00d4ad;
        --accent-dim: #008f78;
        --accent-soft: rgba(0, 212, 173, 0.07);
        --accent-glow: rgba(0, 212, 173, 0.2);
        --secondary: #ffab30;
        --secondary-soft: rgba(255, 171, 48, 0.1);
        --chip: #0e1b2c;
        --chip-hover: #142438;
        --shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
        --font-mono: 'IBM Plex Mono', 'Menlo', 'Courier New', monospace;
        --font-body: 'Noto Sans JP', 'Hiragino Sans', 'Yu Gothic', system-ui, sans-serif;
        --radius: 10px;
        --radius-sm: 6px;
        /* z-index スケール（任意値を使わず段階で管理） */
        --z-header: 10;
        --z-overlay: 100;
      }
      :root[data-theme='light'] {
        --bg: #eef2f7;
        --surface: #ffffff;
        --surface-hover: #f5f8fc;
        --border: #cdd9e8;
        --border-hover: #b0c4d8;
        --text: #0c1828;
        --muted: #6080a0;
        --accent: #007a62;
        --accent-dim: #005d4a;
        --accent-soft: rgba(0, 122, 98, 0.07);
        --accent-glow: rgba(0, 122, 98, 0.14);
        --secondary: #d97000;
        --secondary-soft: rgba(217, 112, 0, 0.09);
        --chip: #e4edf6;
        --chip-hover: #d8e6f0;
        --shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        background-color: var(--bg);
        color: var(--text);
        font-family: var(--font-body);
        line-height: 1.65;
        min-height: 100dvh;
        background-image: radial-gradient(circle, rgba(0, 212, 173, 0.04) 1px, transparent 1px);
        background-size: 30px 30px;
        transition: background-color 0.25s ease, color 0.25s ease;
      }
      :root[data-theme='light'] body {
        background-image: radial-gradient(circle, rgba(0, 100, 80, 0.06) 1px, transparent 1px);
      }
      a { color: inherit; }
      button { font-family: var(--font-body); }
      ::selection { background: var(--accent); color: #020e0b; }
      /* モーション軽減設定を尊重 */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </body>
</html>
